---
import SectionIntro from './SectionIntro.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" id={profile.competenciesIntro.id} data-reveal-group>
  <div class="container section-stack">
    <SectionIntro
      eyebrow={profile.competenciesIntro.eyebrow}
      title={profile.competenciesIntro.title}
      summary={profile.competenciesIntro.summary}
    />
    <ul class="chip-grid" data-reveal>
      {profile.competencies.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
</section>
