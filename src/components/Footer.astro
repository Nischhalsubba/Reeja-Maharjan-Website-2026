---
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__eyebrow">Portfolio</p>
      <h2>{profile.name}</h2>
      <p>{profile.role}</p>
    </div>
    <nav aria-label="Footer quick links" class="site-footer__links">
      <a href="#home">Home</a>
      <a href="#experience">Experience</a>
      <a href="#certifications">Certifications</a>
      <a href="#contact">Contact</a>
    </nav>
    <div class="site-footer__contact">
      <a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
      <a href={`tel:${profile.contact.phone.replaceAll(' ', '')}`}>{profile.contact.phone}</a>
    </div>
  </div>
  <div class="container site-footer__legal">
    <small>© {new Date().getFullYear()} {profile.name}</small>
    <a href="#home">Back to top</a>
  </div>
</footer>
