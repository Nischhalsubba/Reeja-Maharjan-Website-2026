---
import type { ProfileContent } from '../content/profile';

type Props = {
  profile: ProfileContent;
  mode?: 'one-page' | 'blog';
};

const { profile, mode = 'one-page' } = Astro.props;
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__eyebrow">Portfolio</p>
      <h2>{profile.name}</h2>
      <p>{profile.role}</p>
    </div>
    <nav aria-label="Footer quick links" class="site-footer__links">
      <a href={mode === 'blog' ? '/' : '#home'}>Home</a>
      <a href={mode === 'blog' ? '/blog/' : '#experience'}>{mode === 'blog' ? 'Blog' : 'Experience'}</a>
      <a href={mode === 'blog' ? '/#certifications' : '#certifications'}>Certifications</a>
      <a href={mode === 'blog' ? '/#contact' : '#contact'}>Contact</a>
    </nav>
    <div class="site-footer__contact">
      <a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
      <a href={`tel:${profile.contact.phone.replaceAll(' ', '')}`}>{profile.contact.phone}</a>
    </div>
  </div>
  <div class="container site-footer__legal">
    <small>(c) {new Date().getFullYear()} {profile.name}</small>
    <a href={mode === 'blog' ? '/#home' : '#home'}>Back to top</a>
  </div>
</footer>

