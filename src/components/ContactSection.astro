---
import SectionIntro from './SectionIntro.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" id={profile.contactIntro.id} data-reveal-group>
  <div class="container section-stack">
    <SectionIntro
      eyebrow={profile.contactIntro.eyebrow}
      title={profile.contactIntro.title}
      summary={profile.contactIntro.summary}
    />

    <div class="contact-grid">
      <div class="card" data-reveal>
        <h3>Direct Nursing Contact</h3>
        <ul class="contact-list">
          <li><span>Email</span><a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a></li>
          <li><span>Mobile</span><strong>Available on request</strong></li>
          <li><span>Location</span><strong>{profile.contact.location}</strong></li>
          <li><span>LinkedIn</span><a href={profile.contact.linkedin} target="_blank" rel="noopener noreferrer">Profile</a></li>
          {
            profile.contact.instagram && (
              <li>
                <span>Instagram</span>
                <a href={profile.contact.instagram} target="_blank" rel="noopener noreferrer">Profile</a>
              </li>
            )
          }
        </ul>
        <div class="hero__actions">
          <a class="btn btn--primary" href={`mailto:${profile.contact.email}`}>Send Email</a>
          <a class="btn btn--secondary" href={profile.contact.resumeUrl}>Download CV</a>
        </div>
      </div>

      <form
        id="contact-form"
        class="card contact-form"
        data-reveal
        aria-label="Contact form"
        method="POST"
        data-endpoint={profile.contact.formEndpoint}
      >
        <h3>Send an Interview Inquiry</h3>
        <label>
          Name
          <input type="text" name="name" autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" autocomplete="email" />
        </label>
        <label>
          Message
          <textarea name="message" rows="5"></textarea>
        </label>
        <input type="hidden" name="_subject" value="New contact from reejamaharjan.com.np" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <button type="submit" class="btn btn--primary">Send Message</button>
        <div class="form-success-card" hidden>
          <h4>Message sent successfully</h4>
          <p>Thank you for reaching out. Reeja will reply to your email soon.</p>
          <button type="button" class="btn btn--secondary" data-reset-form>Send another message</button>
        </div>
        <p class="form-status form-status--success" role="status" aria-live="polite" hidden>
          Message sent. Reeja will reply soon.
        </p>
        <p class="form-status form-status--error" role="alert" aria-live="assertive" hidden>
          Message could not be sent. Please try again.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  if (form instanceof HTMLFormElement) {
    const configuredEndpoint = form.dataset.endpoint;
    const endpoint =
      configuredEndpoint ||
      import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ||
      'https://formsubmit.co/ajax/maharjanreeja88@gmail.com';
    form.action = endpoint;
    const success = form.querySelector('.form-status--success');
    const error = form.querySelector('.form-status--error');
    const submit = form.querySelector('button[type="submit"]');
    const successCard = form.querySelector('.form-success-card');
    const resetButton = form.querySelector('[data-reset-form]');
    const fields = Array.from(form.querySelectorAll('label, input[type=\"hidden\"], button[type=\"submit\"]'));

    const setSuccessView = (enabled) => {
      fields.forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        el.hidden = enabled;
      });
      if (successCard instanceof HTMLElement) successCard.hidden = !enabled;
    };

    if (resetButton instanceof HTMLButtonElement) {
      resetButton.addEventListener('click', () => {
        setSuccessView(false);
        if (success instanceof HTMLElement) success.hidden = true;
        if (error instanceof HTMLElement) error.hidden = true;
      });
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(submit instanceof HTMLButtonElement)) return;
      submit.disabled = true;
      submit.textContent = 'Sending...';
      if (success instanceof HTMLElement) success.hidden = true;
      if (error instanceof HTMLElement) error.hidden = true;

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' }
        });

        if (!response.ok) throw new Error('Request failed');
        form.reset();
        if (success instanceof HTMLElement) success.hidden = false;
        setSuccessView(true);
      } catch {
        if (error instanceof HTMLElement) error.hidden = false;
      } finally {
        submit.disabled = false;
        submit.textContent = 'Send Message';
      }
    });
  }
</script>
