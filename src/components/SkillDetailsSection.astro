---
import SectionIntro from './SectionIntro.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" data-reveal-group>
  <div class="container section-stack">
    <SectionIntro
      id={profile.skillDetailsIntro.id}
      eyebrow={profile.skillDetailsIntro.eyebrow}
      title={profile.skillDetailsIntro.title}
      summary={profile.skillDetailsIntro.summary}
    />
    <div class="card-grid card-grid--2">
      {profile.skillDetails.map((group) => (
        <article class="card" data-reveal>
          <h3>{group.title}</h3>
          <p>{group.description}</p>
          <ul class="chip-list">
            {group.focus.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
