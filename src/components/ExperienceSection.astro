---
import SectionIntro from './SectionIntro.astro';
import SectionIcon from './SectionIcon.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" id={profile.experienceIntro.id} data-reveal-group>
  <div class="container">
    <article class="section-shell" data-reveal>
      <header class="section-shell__head">
        <span class="section-shell__icon"><SectionIcon name="experience" /></span>
        <SectionIntro
          eyebrow={profile.experienceIntro.eyebrow}
          title={profile.experienceIntro.title}
          summary={profile.experienceIntro.summary}
        />
      </header>
      <div class="section-shell__body">
        <ol class="timeline-list">
          {profile.experience.map((item) => (
            <li class="timeline-list__item">
              <div class="timeline-list__dot" aria-hidden="true"></div>
              <div class="timeline-list__content">
                <div class="timeline-list__row">
                  <h3>{item.role}</h3>
                  <time class="timeline-list__date">{item.period}</time>
                </div>
                <p class="timeline-list__meta">{item.organization} · {item.type}</p>
                <p class="timeline-list__meta">{item.location}</p>
                <ul class="timeline-list__bullets">
                  {item.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
                {
                  item.credential && (
                    <a
                      class="text-link"
                      href={item.credential.src}
                      data-lightbox-src={item.credential.src}
                      data-lightbox-alt={item.credential.alt}
                      data-lightbox-title={item.credential.title}
                      data-lightbox-description={item.credential.description}
                    >
                      View credential
                    </a>
                  )
                }
              </div>
            </li>
          ))}
        </ol>
      </div>
    </article>
  </div>
</section>
