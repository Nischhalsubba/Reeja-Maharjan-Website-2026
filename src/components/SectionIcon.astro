---
type IconName =
  | 'experience'
  | 'education'
  | 'certifications'
  | 'skills'
  | 'languages'
  | 'awards'
  | 'recommendations'
  | 'contact';

type Props = { name: IconName };
const { name } = Astro.props;
---

{
  name === 'experience' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="7" width="18" height="13" rx="2"></rect>
      <path d="M9 7V5a3 3 0 0 1 6 0v2"></path>
    </svg>
  )
}
{
  name === 'education' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="m3 9 9-5 9 5-9 5-9-5Z"></path>
      <path d="M7 12v4c0 1.5 2.2 3 5 3s5-1.5 5-3v-4"></path>
    </svg>
  )
}
{
  name === 'certifications' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="4" y="4" width="16" height="16" rx="2"></rect>
      <path d="m9 12 2 2 4-4"></path>
    </svg>
  )
}
{
  name === 'skills' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="4" y="4" width="6" height="6" rx="1"></rect>
      <rect x="14" y="4" width="6" height="6" rx="1"></rect>
      <rect x="4" y="14" width="6" height="6" rx="1"></rect>
      <rect x="14" y="14" width="6" height="6" rx="1"></rect>
    </svg>
  )
}
{
  name === 'languages' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M3 12h18"></path>
      <path d="M12 3a15 15 0 0 1 0 18"></path>
      <path d="M12 3a15 15 0 0 0 0 18"></path>
    </svg>
  )
}
{
  name === 'awards' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M8 4h8v4a4 4 0 0 1-8 0V4Z"></path>
      <path d="M12 12v4"></path>
      <path d="M8 20h8"></path>
      <path d="M16 6h3a2 2 0 0 1-2 2h-1"></path>
      <path d="M8 6H5a2 2 0 0 0 2 2h1"></path>
    </svg>
  )
}
{
  name === 'recommendations' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M5 7h14"></path>
      <path d="M5 12h10"></path>
      <path d="M5 17h8"></path>
      <rect x="3" y="4" width="18" height="16" rx="2"></rect>
    </svg>
  )
}
{
  name === 'contact' && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="m4 7 8 6 8-6"></path>
      <rect x="3" y="6" width="18" height="12" rx="2"></rect>
    </svg>
  )
}

