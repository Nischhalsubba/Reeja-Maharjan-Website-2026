---
import SectionIntro from './SectionIntro.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" data-reveal-group>
  <div class="container section-stack">
    <SectionIntro
      id={profile.keywordsIntro.id}
      eyebrow={profile.keywordsIntro.eyebrow}
      title={profile.keywordsIntro.title}
      summary={profile.keywordsIntro.summary}
    />
    <ul class="chip-grid" data-reveal>
      {profile.keywords.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
</section>
