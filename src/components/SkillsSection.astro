---
import SectionIntro from './SectionIntro.astro';
import SectionIcon from './SectionIcon.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" id={profile.skillsIntro.id} data-reveal-group>
  <div class="container">
    <article class="section-shell" data-reveal>
      <header class="section-shell__head">
        <span class="section-shell__icon"><SectionIcon name="skills" /></span>
        <SectionIntro
          eyebrow={profile.skillsIntro.eyebrow}
          title={profile.skillsIntro.title}
          summary={profile.skillsIntro.summary}
        />
      </header>
      <div class="section-shell__body">
        <div class="skills-stack">
          {profile.skills.map((group) => (
            <article class="skills-group">
              <h3>{group.title}</h3>
              <ul class="skills-chip-list">
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </article>
  </div>
</section>
