---
import SectionIntro from './SectionIntro.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" id={profile.certificationsIntro.id} data-reveal-group>
  <div class="container section-stack">
    <SectionIntro
      eyebrow={profile.certificationsIntro.eyebrow}
      title={profile.certificationsIntro.title}
      summary={profile.certificationsIntro.summary}
    />
    <div class="card-grid card-grid--2">
      {profile.certifications.map((item) => (
        <article class="card" data-reveal>
          <h3>{item.title}</h3>
          <p>{item.issuer}</p>
          <p class="muted">{item.date}</p>
          <p>{item.note}</p>
          <a
            class="text-link"
            href={item.credentialUrl}
            data-lightbox-src={item.preview.src}
            data-lightbox-alt={item.preview.alt}
            data-lightbox-title={item.preview.title}
            data-lightbox-description={item.preview.description}
          >
            Show credential
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
