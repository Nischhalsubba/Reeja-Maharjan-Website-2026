---
import type { Profile } from '../content/profile';

interface Props {
  profile: Profile;
}

const { profile } = Astro.props as Props;
const topSkills = profile.practiceAreas.slice(0, 3);
const topCredentials = profile.credentials.slice(0, 2);
const heroPortrait = profile.images?.find((img) => img.usage === 'hero' && img.public && img.featured)
  ?? profile.images?.find((img) => img.usage === 'hero' && img.public);
---

<div class="device-wrap device-wrap--hero" data-hero-device data-tilt-card data-cursor="card">
  <div class="device-frame">
    <div class="device-notch" aria-hidden="true"></div>
    <div class="device-screen">
      <header class="device-header">
        <div class="device-header__identity">
          {
            heroPortrait && (
              <img
                src={heroPortrait.file}
                alt={heroPortrait.alt}
                class="device-avatar"
                loading="lazy"
                decoding="async"
                onerror="this.style.display='none'"
              />
            )
          }
          <div>
            <p class="device-label">Clinical Profile</p>
            <p class="device-name">{profile.name}</p>
            <p class="device-subname">Licensed Registered Nurse (Nepal)</p>
          </div>
        </div>
        <span class="device-chip">NNC RN</span>
      </header>

      <section class="device-panel device-panel--hero">
        <div class="device-status-row">
          <span class="device-status-dot" aria-hidden="true"></span>
          <span class="device-status-text">Immediate availability</span>
        </div>
        <div class="device-mini-grid">
          <div>
            <p class="device-panel__title">Location</p>
            <p class="device-value">Lalitpur, Nepal</p>
          </div>
          <div>
            <p class="device-panel__title">Relocation</p>
            <p class="device-value">Accepted</p>
          </div>
        </div>
      </section>

      <section class="device-panel">
        <p class="device-panel__title">Primary Clinical Focus</p>
        <ul class="device-list">
          {topSkills.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="device-panel device-panel--compact">
        <div>
          <p class="device-panel__title">Key Credentials</p>
          <p class="device-value">{topCredentials.map((item) => item.title.replace('Certificate', '').trim()).join(' · ')}</p>
        </div>
      </section>

      <a href="/#credentials" class="device-link" data-scroll-target="#credentials" data-cursor="link">
        View verification
      </a>
    </div>
  </div>
</div>

