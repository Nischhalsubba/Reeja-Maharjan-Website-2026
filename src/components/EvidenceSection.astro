---
import SectionIntro from './SectionIntro.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
---

<section class="section" id={profile.evidenceIntro.id} data-reveal-group>
  <div class="container section-stack">
    <SectionIntro
      eyebrow={profile.evidenceIntro.eyebrow}
      title={profile.evidenceIntro.title}
      summary={profile.evidenceIntro.summary}
    />
    <div class="card-grid card-grid--3">
      {profile.evidence.map((item) => (
        <article class="card evidence-card" data-reveal>
          <p class="muted">{item.category}</p>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <a
            class="text-link"
            href={item.src}
            data-lightbox-src={item.src}
            data-lightbox-alt={item.alt}
            data-lightbox-title={item.title}
            data-lightbox-description={item.description}
          >
            View credential
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

