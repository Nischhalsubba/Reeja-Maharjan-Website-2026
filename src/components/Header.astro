---
type Props = {
  name: string;
  showAwards?: boolean;
  mode?: 'one-page' | 'blog';
};

const { name, showAwards = false, mode = 'one-page' } = Astro.props;
---

<header class="site-header" aria-label="Primary">
  <div class="container site-header__inner">
    <a class="brand" href={mode === 'blog' ? '/' : '#home'} aria-label="Go to home section">
      <span class="brand__mark">RM</span>
      <span class="brand__text">
        <strong>{name}</strong>
        <small>Registered Nurse</small>
      </span>
    </a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">
      Menu
    </button>

    {
      mode === 'one-page' ? (
        <nav class="desktop-nav" aria-label="Section navigation">
          <a href="#home">Home</a>
          <a href="#profile">Profile</a>
          <a href="#experience">Experience</a>
          <a href="#education">Education</a>
          <a href="#skills">Skills</a>
          <a href="/blog/">Blog</a>
          <a href="#contact">Contact Me</a>
        </nav>
      ) : (
        <nav class="desktop-nav" aria-label="Site navigation">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/#contact">Contact Me</a>
        </nav>
      )
    }
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    {
      mode === 'one-page' ? (
        <nav class="mobile-nav__panel" aria-label="Mobile section navigation">
          <a href="#home">Home</a>
          <a href="#profile">Profile</a>
          <a href="#competencies">Core Competencies</a>
          <a href="#experience">Experience</a>
          <a href="#education">Education</a>
          <a href="#certifications">Certifications</a>
          <a href="#skills">Skills</a>
          <a href="#skill-details">Skill Details</a>
          <a href="#languages">Languages</a>
          {showAwards && <a href="#awards">Awards</a>}
          <a href="#recommendations">Recommendations</a>
          <a href="#personal-details">Personal Details</a>
          <a href="#evidence">Evidence</a>
          <a href="#keywords">Keywords</a>
          <a href="/blog/">Blog</a>
          <a href="#contact">Contact Me</a>
        </nav>
      ) : (
        <nav class="mobile-nav__panel" aria-label="Mobile site navigation">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/#contact">Contact Me</a>
        </nav>
      )
    }
  </div>
</header>
