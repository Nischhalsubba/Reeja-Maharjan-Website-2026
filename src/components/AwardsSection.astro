---
import SectionIntro from './SectionIntro.astro';
import SectionIcon from './SectionIcon.astro';
import type { ProfileContent } from '../content/profile';

type Props = { profile: ProfileContent };
const { profile } = Astro.props;
const hasAwards = profile.awards.length > 0;
---

{
  hasAwards && (
    <section class="section" id={profile.awardsIntro.id} data-reveal-group>
      <div class="container">
        <article class="section-shell" data-reveal>
          <header class="section-shell__head">
            <span class="section-shell__icon"><SectionIcon name="awards" /></span>
            <SectionIntro
              eyebrow={profile.awardsIntro.eyebrow}
              title={profile.awardsIntro.title}
              summary={profile.awardsIntro.summary}
            />
          </header>
          <div class="section-shell__body">
            <div class="card-grid card-grid--1">
              {profile.awards.map((award) => (
                <article class="card">
                  <h3>{award.title}</h3>
                  <p>{award.note}</p>
                </article>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>
  )
}
