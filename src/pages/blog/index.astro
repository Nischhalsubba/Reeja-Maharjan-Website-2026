---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../content/blog';

const posts = blogPosts;

const formatDate = (value: string) =>
  new Date(value).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Blog | Reeja Maharjan"
  description="Evidence-based nursing articles on maternal care, newborn care, documentation, safeguarding, and Nepal nursing careers."
>
  <section class="section blog-list">
    <div class="container section-stack">
      <div class="section-intro">
        <p class="section-intro__eyebrow">Blog</p>
        <h1>Nursing Blog: Practical Guides for Parents, Nurses, and Recruiters</h1>
        <p>
          Evidence-based articles on maternal care, newborn support, general care nursing,
          counselling, safe handover, and nurse career growth in Nepal.
        </p>
      </div>

      <div class="card-grid card-grid--1">
        {posts.map((post) => (
          <article class="card blog-card" data-card-link data-card-href={`/blog/${post.slug}/`}>
            <p class="blog-card__meta">
              <span>{formatDate(post.publishedAt)}</span>
              <span>{post.readMinutes} min read</span>
            </p>
            <h2>{post.title}</h2>
            <p>{post.excerpt}</p>
            <ul class="chip-list">
              {post.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
            <p class="blog-card__keyword">
              <strong>Primary topic:</strong> {post.primaryKeyword}
            </p>
            <a class="text-link" href={`/blog/${post.slug}/`}>Read article</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
