---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../content/blogPosts';
---

<BaseLayout
  page="blog"
  pageType="profile"
  title="Blog"
  description="Clinical nursing articles and practical notes by Reeja Maharjan."
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <header class="mb-10">
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-[var(--accent)]">Blog</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[var(--ink)]">Clinical Notes and Articles</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--ink-muted)]">
        Practical nursing articles focused on maternal-newborn support, ward workflow, documentation, and care continuity.
      </p>
    </header>

    <div class="grid gap-5">
      {blogPosts.map((post) => (
        <article class="border border-[var(--line)] bg-white p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-[var(--ink-muted)]">{post.publishedAt}</p>
          <h2 class="mt-3 text-2xl font-semibold text-[var(--ink)]">
            <a href={`/blog/${post.slug}/`} class="hover:text-[var(--accent)]">
              {post.title}
            </a>
          </h2>
          <p class="mt-3 text-base leading-7 text-[var(--ink-muted)]">{post.description}</p>
          <a href={`/blog/${post.slug}/`} class="mt-5 inline-block text-sm font-semibold uppercase tracking-[0.1em] text-[var(--accent)]">
            Read article
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

