---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../content/blogPosts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: (typeof blogPosts)[number] };
---

<BaseLayout
  page="blog-detail"
  pageType="profile"
  title={post.title}
  description={post.description}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <a href="/blog/" class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--accent)]">
      Back to blog
    </a>

    <header class="mt-6 border-b border-[var(--line)] pb-6">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-[var(--ink-muted)]">{post.publishedAt}</p>
      <h1 class="mt-3 text-4xl font-semibold leading-tight tracking-tight text-[var(--ink)]">{post.title}</h1>
      <p class="mt-4 text-base leading-7 text-[var(--ink-muted)]">{post.description}</p>
    </header>

    <div class="mt-8 grid gap-5">
      {post.body.map((paragraph) => (
        <p class="text-lg leading-8 text-[var(--ink)]">{paragraph}</p>
      ))}
    </div>
  </article>
</BaseLayout>

