---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts, getBlogPost } from '../../content/blog';
import { profile } from '../../content/profile';

export const getStaticPaths = () =>
  blogPosts.map((post) => ({
    params: { slug: post.slug }
  }));

const { slug } = Astro.params;
const post = slug ? getBlogPost(slug) : undefined;

if (!post) {
  return Astro.redirect('/404');
}

const published = new Date(post.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const updated = new Date(post.updatedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const relatedPosts = post.relatedSlugs
  .map((relatedSlug) => blogPosts.find((candidate) => candidate.slug === relatedSlug))
  .filter(Boolean);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.metaDescription,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt,
  author: {
    '@type': 'Person',
    name: profile.name,
    jobTitle: profile.role
  },
  publisher: {
    '@type': 'Person',
    name: profile.name
  },
  keywords: [post.primaryKeyword, ...post.supportingKeywords]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
---

<BaseLayout title={`${post.title} | Reeja Blog`} description={post.metaDescription}>
  <article class="section blog-post">
    <div class="container section-stack">
      <a class="text-link blog-post__back" href="/blog/">Back to blog</a>

      <header class="section-intro">
        <p class="section-intro__eyebrow">Clinical Nursing Article</p>
        <h1>{post.title}</h1>
        <p>{post.excerpt}</p>
        <p class="blog-card__meta">
          <span>{published}</span>
          <span>Updated {updated}</span>
          <span>{post.readMinutes} min read</span>
        </p>
        <ul class="chip-list">
          {post.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      </header>

      <div class="blog-post__layout">
        <aside class="card blog-post__aside">
          <div class="blog-post__quick-answer">
            <p class="section-intro__eyebrow">Quick answer</p>
            <ul>
              {post.quickAnswer.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="blog-post__toc">
            <p class="section-intro__eyebrow">On this page</p>
            <ol>
              {post.sections.map((section) => (
                <li><a href={`#${section.id}`}>{section.title}</a></li>
              ))}
            </ol>
          </div>

          <div class="blog-post__cta card">
            <h2>{post.cta.title}</h2>
            <p>{post.cta.text}</p>
            <a class="button button--primary" href={post.cta.href}>{post.cta.label}</a>
          </div>
        </aside>

        <div class="blog-post__main">
          <div class="card blog-post__content">
            {post.intro.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          {post.sections.map((section) => (
            <section class="card blog-post__section" id={section.id}>
              <h2>{section.title}</h2>
              {section.paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
              {section.bullets && (
                <ul class="blog-post__list">
                  {section.bullets.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
            </section>
          ))}

          <section class="card blog-post__author">
            <p class="section-intro__eyebrow">Author</p>
            <h2>Reeja Maharjan, Registered Nurse</h2>
            <p>
              Reeja Maharjan is an NNC-licensed registered nurse with verified experience in
              maternal-newborn support, general care, counselling, documentation, and
              safeguarding-aware communication.
            </p>
            <p class="note">Last updated: {updated}</p>
          </section>

          <section class="card blog-post__faq">
            <p class="section-intro__eyebrow">FAQ</p>
            <h2>Frequently Asked Questions</h2>
            <div class="blog-post__faq-list">
              {post.faq.map((item) => (
                <div class="blog-post__faq-item">
                  <h3>{item.question}</h3>
                  <p>{item.answer}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="card blog-post__sources">
            <p class="section-intro__eyebrow">Sources</p>
            <h2>Reputable References</h2>
            <ul class="blog-post__list">
              {post.sources.map((source) => (
                <li>
                  <a href={source.href} target="_blank" rel="noreferrer">{source.label}</a>
                </li>
              ))}
            </ul>
          </section>

          <section class="card blog-post__disclaimer">
            <p class="section-intro__eyebrow">Safety note</p>
            <p>{post.disclaimer}</p>
          </section>

          {relatedPosts.length > 0 && (
            <section class="card blog-post__related">
              <p class="section-intro__eyebrow">Read next</p>
              <h2>Related Articles</h2>
              <div class="card-grid card-grid--2">
                {relatedPosts.map((relatedPost) => (
                  <article class="card blog-card" data-card-link data-card-href={`/blog/${relatedPost.slug}/`}>
                    <h3>{relatedPost.title}</h3>
                    <p>{relatedPost.excerpt}</p>
                    <a class="text-link" href={`/blog/${relatedPost.slug}/`}>Read article</a>
                  </article>
                ))}
              </div>
            </section>
          )}
        </div>
      </div>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </article>
</BaseLayout>
